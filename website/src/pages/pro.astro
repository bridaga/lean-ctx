---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title={t('pro.title')} description={t('pro.description')}
  noindex={true}
  breadcrumbs={[{ name: t('common.home'), url: lp('/') }, { name: 'Pro', url: lp('/pro/') }]}>

<!-- ═══════ HERO ═══════ -->
<section class="section-hero">
  <div class="content-grid">
    <div class="animate-entrance">
      <p class="fluid-label text-accent" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2.5rem);">
        {t('pro.heroLabel')}
      </p>
    </div>
    <h1 class="font-display fluid-h1 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 3rem);">
      {t('pro.heroTitle')}<br/>
      <span class="gradient-text">{t('pro.heroTitleHighlight')}</span>
    </h1>
    <p class="fluid-body text-muted animate-entrance stagger-2" style="margin-bottom: 2rem; max-width: 40rem;" set:html={t('pro.heroDesc')} />
    <div class="pro-price-hero animate-entrance stagger-3">
      <span class="pro-price-amount">$9</span>
      <span class="pro-price-period">{t('pro.perMonth')}</span>
      <span class="pro-price-note">{t('pro.priceNote')}</span>
    </div>
    <div class="pro-hero-actions animate-entrance stagger-3">
      <span class="pro-or">{t('pro.comingSoon')}</span>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ HOW IT WORKS ═══════ -->
<section class="section-y">
  <div class="content-grid" style="max-width: 48rem;">
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance" style="margin-bottom: clamp(1.5rem, 1rem + 1vw, 2.5rem);">
      {t('pro.howItWorksTitle')}
    </h2>
    <div class="pro-steps animate-entrance stagger-1">
      <div class="pro-step">
        <div class="pro-step-num">1</div>
        <div>
          <h3 class="pro-step-title">{t('pro.step1Title')}</h3>
          <p class="pro-step-desc">{t('pro.step1Desc')}</p>
        </div>
      </div>
      <div class="pro-step">
        <div class="pro-step-num">2</div>
        <div>
          <h3 class="pro-step-title">{t('pro.step2Title')}</h3>
          <p class="pro-step-desc">{t('pro.step2Desc')}</p>
        </div>
      </div>
      <div class="pro-step">
        <div class="pro-step-num">3</div>
        <div>
          <h3 class="pro-step-title">{t('pro.step3Title')}</h3>
          <p class="pro-step-desc">{t('pro.step3Desc')}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ COMPARISON ═══════ -->
<section class="section-y">
  <div class="content-grid">
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance" style="margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3.5rem); text-align: center;">
      {t('pro.freeVsProTitle')}
    </h2>
    <div class="comparison-grid animate-entrance stagger-1">

      <!-- FREE -->
      <div class="comparison-card">
        <div class="comparison-header">
          <h3 class="comparison-tier">{t('pro.freeTier')}</h3>
          <div class="comparison-price">
            <span class="comp-amount">$0</span>
            <span class="comp-period">{t('pro.forever')}</span>
          </div>
        </div>
        <ul class="comparison-features">
          <li>{t('pro.freeFeature1')}</li>
          <li>{t('pro.freeFeature2')}</li>
          <li>{t('pro.freeFeature3')}</li>
          <li>{t('pro.freeFeature4')}</li>
          <li>{t('pro.freeFeature5')}</li>
          <li>{t('pro.freeFeature6')}</li>
          <li>{t('pro.freeFeature7')}</li>
          <li>{t('pro.freeFeature8')}</li>
          <li>{t('pro.freeFeature9')}</li>
          <li class="feature-absent">{t('pro.freeFeatureAbsent1')}</li>
          <li class="feature-absent">{t('pro.freeFeatureAbsent2')}</li>
        </ul>
        <a href="https://github.com/yvgude/lean-ctx" class="comparison-cta comparison-cta-secondary">
          {t('pro.installFree')}
        </a>
      </div>

      <!-- PRO -->
      <div class="comparison-card comparison-card-featured">
        <div class="comparison-badge">{t('pro.recommended')}</div>
        <div class="comparison-header">
          <h3 class="comparison-tier">{t('pro.proTier')}</h3>
          <div class="comparison-price">
            <span class="comp-amount">$9</span>
            <span class="comp-period">{t('pro.perMonth')}</span>
          </div>
        </div>
        <ul class="comparison-features">
          <li><strong>{t('pro.proFeature1')}</strong></li>
          <li class="feature-highlight">{t('pro.proFeature2')}</li>
          <li class="feature-highlight">{t('pro.proFeature3')}</li>
          <li class="feature-highlight">{t('pro.proFeature4')}</li>
          <li>{t('pro.proFeature5')}</li>
          <li>{t('pro.proFeature6')}</li>
          <li>{t('pro.proFeature7')}</li>
          <li>{t('pro.proFeature8')}</li>
          <li>{t('pro.proFeature9')}</li>
          <li>{t('pro.proFeature10')}</li>
        </ul>
        <span class="comparison-cta comparison-cta-primary" style="opacity: 0.5; cursor: default;">
          {t('pro.comingSoon')}
        </span>
      </div>

    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ OPEN SOURCE PROMISE ═══════ -->
<section class="section-y">
  <div class="content-grid" style="max-width: 48rem;">
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance" style="margin-bottom: clamp(1.5rem, 1rem + 1vw, 2.5rem);">
      {t('pro.openSourceTitle')}
    </h2>
    <div class="space-y-6 animate-entrance stagger-1">
      <p class="fluid-body text-muted" set:html={t('pro.openSourceDesc1')} />
      <p class="fluid-body text-muted" set:html={t('pro.openSourceDesc2')} />
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════ FAQ ═══════ -->
<section class="section-y">
  <div class="content-grid" style="max-width: 48rem;">
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance" style="margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3.5rem);">
      {t('pro.faqTitle')}
    </h2>
    <div class="faq-list animate-entrance stagger-1">
      <details class="faq-item">
        <summary class="faq-question">{t('pro.faq1q')}</summary>
        <p class="faq-answer">{t('pro.faq1a')}</p>
      </details>
      <details class="faq-item">
        <summary class="faq-question">{t('pro.faq2q')}</summary>
        <p class="faq-answer">{t('pro.faq2a')}</p>
      </details>
      <details class="faq-item">
        <summary class="faq-question">{t('pro.faq3q')}</summary>
        <p class="faq-answer" set:html={t('pro.faq3a')} />
      </details>
      <details class="faq-item">
        <summary class="faq-question">{t('pro.faq4q')}</summary>
        <p class="faq-answer">{t('pro.faq4a')}</p>
      </details>
      <details class="faq-item">
        <summary class="faq-question">{t('pro.faq5q')}</summary>
        <p class="faq-answer">{t('pro.faq5a')}</p>
      </details>
    </div>
  </div>
</section>

<!-- ═══════ FINAL CTA ═══════ -->
<section class="section-y" style="text-align: center;">
  <div class="content-grid">
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance" style="margin-bottom: 1rem;">
      {t('pro.ctaTitle')}
    </h2>
    <p class="fluid-body text-muted animate-entrance stagger-1" style="margin-bottom: 2rem;">
      {t('pro.ctaDesc')}
    </p>
    <div class="pro-final-code animate-entrance stagger-2">
      <code>{t('pro.ctaCode')}</code>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .pro-price-hero {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .pro-price-amount {
    font-family: var(--font-display);
    font-size: clamp(3rem, 2rem + 3vw, 5rem);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }
  .pro-price-period {
    font-size: 1.25rem;
    color: var(--color-muted);
    margin-right: 1rem;
  }
  .pro-price-note {
    font-size: 0.8125rem;
    color: var(--color-muted);
    width: 100%;
    margin-top: 0.5rem;
  }

  .pro-hero-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .pro-cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .pro-cta-primary:hover { opacity: 0.88; }
  .pro-or {
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  .pro-or code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    color: var(--color-accent);
  }

  .pro-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .pro-step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .pro-step-num {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
  }
  .pro-step-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-text-bright);
    margin-bottom: 0.375rem;
  }
  .pro-step-desc {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .comparison-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 0.5rem + 1.5vw, 2rem);
    max-width: 52rem;
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .comparison-grid {
      grid-template-columns: 1fr;
      max-width: 24rem;
    }
  }

  .comparison-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease;
  }
  .comparison-card:hover { border-color: var(--color-border-light); }
  .comparison-card-featured {
    border-color: var(--color-accent);
    background: linear-gradient(180deg, rgba(52, 211, 153, 0.04) 0%, var(--color-surface) 40%);
  }
  .comparison-card-featured:hover { border-color: var(--color-accent-bright); }

  .comparison-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 1rem;
    border-radius: 2rem;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .comparison-header { margin-bottom: 1.5rem; }
  .comparison-tier {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-bright);
    margin-bottom: 0.75rem;
  }
  .comparison-price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .comp-amount {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 1.5vw, 3rem);
    font-weight: 700;
    color: var(--color-text-bright);
    line-height: 1;
  }
  .comp-period {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .comparison-features {
    list-style: none;
    padding: 0;
    margin: 0 0 auto 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-bottom: 2rem;
  }
  .comparison-features li {
    font-size: 0.875rem;
    color: var(--color-text);
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.5;
  }
  .comparison-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.8rem;
  }
  .comparison-features li strong {
    color: var(--color-text-bright);
    font-weight: 500;
  }
  .comparison-features li.feature-absent::before {
    content: '—';
    color: var(--color-muted);
  }
  .comparison-features li.feature-absent {
    color: var(--color-muted);
  }
  .comparison-features li.feature-highlight {
    color: var(--color-accent);
    font-weight: 500;
  }
  .comparison-features li.feature-highlight::before {
    content: '★';
  }

  .comparison-cta {
    display: block;
    text-align: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
    margin-top: auto;
  }
  .comparison-cta-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .comparison-cta-primary:hover { background: var(--color-accent-bright); }
  .comparison-cta-secondary {
    border: 1px solid var(--color-border-light);
    color: var(--color-text-bright);
  }
  .comparison-cta-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .faq-item:first-child {
    border-top: 1px solid var(--color-border);
  }
  .faq-question {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-bright);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 1.25rem;
    transition: transform 0.2s ease;
  }
  .faq-item[open] .faq-question::after {
    transform: rotate(45deg);
  }
  .faq-answer {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 40rem;
  }
  .faq-answer code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface-2);
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    color: var(--color-accent);
  }

  .pro-final-code {
    display: inline-block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1rem 2.5rem;
  }
  .pro-final-code code {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--color-accent);
  }

  :global(.pro-price-hero strong, .faq-answer strong, .space-y-6 strong) {
    color: var(--color-text-bright);
    font-weight: 600;
  }
</style>
